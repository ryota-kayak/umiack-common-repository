# UMIACK: Force fresh loader scripts (Safari cache fix)
<FilesMatch "loader.*\.js$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-cache, no-store, must-revalidate, proxy-revalidate, max-age=0"
        Header always set Pragma "no-cache"
        Header always set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
        Header unset ETag
    </IfModule>
    FileETag None
</FilesMatch>
